                        <svg viewBox="64 64 896 896" width="12" height="12" fill="currentColor"><path d="M884 256h-75c-5.1 0-9.9 2.5-12.9 6.6L512 654.2 227.9 262.6c-3-4.1-7.8-6.6-12.9-6.6h-75c-6.5 0-10.3 7.4-6.5 12.7l352.6 486.1c12.8 17.6 39 17.6 51.7 0l352.6-486.1c3.9-5.3.1-12.7-6.4-12.7z"></path></svg>
                    </button>
                    <div id="ios-menu" class="dropdown-menu">
                        <a href="shadowrocket://add/sub://<%= data.suburl_base64 %>?title=<%= encodeURIComponent(data.email) %>" class="dropdown-item">Shadowrocket</a>
                        <a href="streisand://import/<%= encodeURIComponent(data.suburl) %>" class="dropdown-item">Streisand</a>
                        <a href="v2raytun://install-sub?url=<%= encodeURIComponent(data.suburl) %>" class="dropdown-item">V2rayTun</a>
                        <a href="foxray://install-sub?url=<%= encodeURIComponent(data.suburl) %>" class="dropdown-item">FoXray</a>
                        <a href="hiddify://install-config?url=<%= encodeURIComponent(data.suburl) %>&name=<%= encodeURIComponent(data.email) %>" class="dropdown-item">Hiddify Next</a>
                    </div>
                </div>
            </div>

            <% if (data.configs && data.configs.length > 0) { %>
            <div class="configs-section">
                <div style="display:flex; justify-content:space-between; align-items:center; margin-bottom:16px;">
                    <h3 class="configs-title" style="margin:0;">کانفیگ‌های شما</h3>
                    <button class="btn-copy-sm" style="margin:0; background:rgba(47,129,247,0.15); color:#79c0ff; border-color:rgba(47,129,247,0.3);" onclick="copySpecificText(`<%= data.configs.join('\\n').replace(/`/g, '\\`').replace(/\\$/g, '\\\\$') %>`)">کپی همه</button>
                </div>
                <div class="configs-list">
                    <% data.configs.forEach((config, index) => { 
                        let protocol = "VPN";
                        try { protocol = config.split('://')[0].toUpperCase(); } catch(e) {}
                        let configName = `کانفیگ شماره ${index + 1}`;
                        try { if (config.includes('#')) { configName = decodeURIComponent(config.split('#').pop()); } } catch(e) {}
                    %>
                    <div class="config-item">
                        <div class="config-info">
                            <span class="config-badge"><%= protocol %></span>
                            <span class="config-name"><%= configName %></span>
                        </div>
                        <div class="config-actions">
                            <button class="btn-qr" onclick="showQR('<%= config %>')" title="نمایش QR Code">
                                <svg viewBox="0 0 24 24"><path d="M3 11h8V3H3v8zm2-6h4v4H5V5zm8-2v8h8V3h-8zm6 6h-4V5h4v4zM3 21h8v-8H3v8zm2-6h4v4H5v-4zm13-2h-2v2h-2v-2h-2v2h-2v-2h-2v2h-2v2h2v-2h2v2h2v-2h2v2h2v-2h2v2h-2v2h2v-2h2v2h2v-2h-2v-2h-2v-2z"/></svg>
                            </button>
                            <button class="btn-copy-sm" onclick="copySpecificText('<%= config.replace(/'/g, "\\'") %>')">کپی</button>
                        </div>
                    </div>
                    <% }); %>
                </div>
            </div>
            <% } %>

            <div class="action-links">
                <% if (data.TELEGRAM_URL) { %>
                <a href="<%= data.TELEGRAM_URL %>?text=سلام من شناسه <%= data.email %> هستم" target="_blank" class="btn-link btn-telegram">
                    <svg viewBox="0 0 24 24"><path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm4.64 6.8c-.15 1.58-.8 5.42-1.13 7.19-.14.75-.42 1-.68 1.03-.58.05-1.02-.38-1.58-.75-.88-.58-1.38-.94-2.23-1.5-.99-.65-.35-1.01.22-1.59.15-.15 2.71-2.48 2.76-2.69.01-.03.01-.14-.07-.19-.08-.05-.19-.02-.27 0-.11.03-1.84 1.18-5.18 3.44-.49.33-.93.5-1.33.49-.44-.01-1.28-.25-1.9-.45-.77-.25-1.38-.38-1.33-.8.03-.22.35-.45.98-.69 3.85-1.68 6.41-2.78 7.69-3.32 3.65-1.53 4.41-1.8 4.9-1.81.11 0 .35.03.5.15.13.1.17.24.18.35-.01.07-.01.21-.02.3z"/></svg>
                    پشتیبانی تلگرام
                </a>
                <% } %>
                
                <% if (data.WHATSAPP_URL) { %>
                <a href="<%= data.WHATSAPP_URL %>?text=سلام من شناسه <%= data.email %> هستم" target="_blank" class="btn-link btn-whatsapp">
                    <svg viewBox="0 0 24 24"><path d="M19.05 4.91A9.816 9.816 0 0 0 12.04 2c-5.46 0-9.91 4.45-9.91 9.91 0 1.75.46 3.45 1.32 4.95L2 22l5.25-1.38c1.45.8 3.08 1.22 4.79 1.22 5.46 0 9.91-4.45 9.91-9.91 0-2.65-1.03-5.14-2.9-7.02zm-7.01 15.24c-1.48 0-2.93-.4-4.2-1.15l-.3-.18-3.12.82.83-3.04-.2-.31a8.264 8.264 0 0 1-1.26-4.38c0-4.54 3.7-8.24 8.24-8.24 2.2 0 4.27.86 5.82 2.42a8.183 8.183 0 0 1 2.41 5.83c.02 4.54-3.68 8.23-8.22 8.23zm4.52-6.16c-.25-.12-1.47-.72-1.69-.81-.23-.08-.39-.12-.56.12-.17.25-.64.81-.79.98-.15.17-.3.19-.55.07-.25-.12-1.05-.39-2-1.24-.74-.66-1.23-1.47-1.38-1.72-.15-.25-.02-.38.11-.51.11-.11.25-.29.37-.43s.17-.25.25-.41c.08-.17.04-.31-.02-.43s-.56-1.34-.76-1.84c-.2-.48-.41-.42-.56-.43h-.48c-.17 0-.45.06-.69.32-.25.25-.94.92-.94 2.24s.96 2.6 1.1 2.78c.14.19 1.9 2.9 4.58 4.06.64.28 1.14.45 1.53.58.64.2 1.22.17 1.68.1.51-.08 1.47-.6 1.68-1.18.21-.58.21-1.08.15-1.18-.05-.1-.22-.16-.47-.28z"/></svg>
                    پشتیبانی واتساپ
                </a>
                <% } %>
            </div>
        </div>
    </div>

    <div id="toast" class="toast">
        <svg viewBox="0 0 24 24"><path d="M9 16.17L4.83 12l-1.42 1.41L9 19 21 7l-1.41-1.41z"/></svg>
        لینک با موفقیت کپی شد!
    </div>

    <!-- QR Modal -->
    <div id="qrModal" class="modal-overlay" onclick="closeQR(event)">
        <div class="modal-content" onclick="event.stopPropagation()">
            <h3 style="margin: 0 0 16px 0; font-size: 16px;">اسکن با گوشی دوم</h3>
            <div id="qrcode" class="qr-container"></div>
            <button class="modal-close" onclick="closeQR(null)">بستن</button>
        </div>
    </div>

    <!-- Announcement Modal -->
    <div id="annModal" class="modal-overlay" onclick="closeAnn(event)">
        <div class="modal-content" onclick="event.stopPropagation()">
            <div id="annIcon" style="margin-bottom: 16px; display: flex; justify-content: center;"></div>
            <h3 id="annDate" style="margin: 0 0 12px 0; font-size: 14px; color: var(--text-secondary); font-family: var(--font-en);"></h3>
            <p id="annText" style="margin: 0 0 24px 0; font-size: 15px; line-height: 1.6; text-align: right; direction: rtl; word-break: break-word;"></p>
            <button class="modal-close" onclick="closeAnn(null)">متوجه شدم</button>
        </div>
    </div>

    <script>
        function showAnnouncement(type, date, message) {
            const modal = document.getElementById('annModal');
            const iconContainer = document.getElementById('annIcon');
            const dateEl = document.getElementById('annDate');
            const textEl = document.getElementById('annText');
            
            let iconPath = "M11 15h2v2h-2v-2zm0-8h2v6h-2V7zm.99-5C6.47 2 2 6.48 2 12s4.47 10 9.99 10C17.52 22 22 17.52 22 12S17.52 2 11.99 2zM12 20c-4.42 0-8-3.58-8-8s3.58-8 8-8 8 3.58 8 8-3.58 8-8 8z";
            let iconColor = "#79c0ff";
            if (type === 'danger') {
                iconPath = "M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm1 15h-2v-2h2v2zm0-4h-2V7h2v6z";
                iconColor = "#ffb1af";
            } else if (type === 'warning') {
                iconColor = "#f2cc79";
            } else if (type === 'success') {
                iconPath = "M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm-2 15l-5-5 1.41-1.41L10 14.17l7.59-7.59L19 8l-9 9z";
                iconColor = "#7ee787";
            }
            
            iconContainer.innerHTML = `<svg viewBox="0 0 24 24" style="width: 48px; height: 48px; fill: ${iconColor};"><path d="${iconPath}"/></svg>`;
            dateEl.innerText = date;
            dateEl.style.display = date ? 'block' : 'none';
            textEl.innerText = message;
            
            modal.classList.add('show');
        }

        function closeAnn(e) {
            if (e && e.target !== document.getElementById('annModal')) return;
            document.getElementById('annModal').classList.remove('show');
        }

        let qrcode = null;

        function showQR(text) {
            const modal = document.getElementById('qrModal');
            const qrContainer = document.getElementById('qrcode');
            qrContainer.innerHTML = ''; // clear previous
            
            qrcode = new QRCode(qrContainer, {
                text: text,
                width: 220,
                height: 220,
                colorDark : "#000000",
                colorLight : "#ffffff",
                correctLevel : QRCode.CorrectLevel.M
            });

            modal.classList.add('show');
        }

        function closeQR(e) {
            if (e && e.target !== document.getElementById('qrModal')) return;
            document.getElementById('qrModal').classList.remove('show');
        }

        function copyUrl() {
            const input = document.getElementById('subUrl');
            input.select();
            input.setSelectionRange(0, 99999);
            copySpecificText(input.value);
        }

        function copySpecificText(text) {
            try {
                navigator.clipboard.writeText(text).then(() => {
                    showToast();
                }).catch(() => {
                    fallbackCopy(text);
                });
            } catch (err) {
                fallbackCopy(text);
            }
        }
        
        function fallbackCopy(text) {
            const textarea = document.createElement("textarea");
            textarea.value = text;
            textarea.style.position = "fixed";
            textarea.style.opacity = "0";
            document.body.appendChild(textarea);
            textarea.select();
            document.execCommand("copy");
            document.body.removeChild(textarea);
            showToast();
        }

        function toggleDropdown(id) {
            const menu = document.getElementById(id);
            const isShowing = menu.classList.contains('show');
            
            // Close all
            document.querySelectorAll('.dropdown-menu').forEach(el => el.classList.remove('show'));
            
            if (!isShowing) {
                menu.classList.add('show');
            }
        }

        // Close dropdowns when clicking outside
        document.addEventListener('click', (e) => {
            if (!e.target.closest('.import-col')) {
                document.querySelectorAll('.dropdown-menu').forEach(el => el.classList.remove('show'));
            }
        });

        function showToast() {
            const toast = document.getElementById('toast');
            toast.classList.add('show');
            setTimeout(() => {
                toast.classList.remove('show');
            }, 3000);
        }

        // Animate progress bars on load
        document.addEventListener("DOMContentLoaded", () => {
            setTimeout(() => {
                const bars = document.querySelectorAll('.progress-bar');
                bars.forEach(bar => {
                    bar.style.width = bar.getAttribute('data-target');
                });
            }, 300);
        });
    </script>
</body>
</html>
