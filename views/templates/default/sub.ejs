<!DOCTYPE html>
<html lang="fa" dir="rtl">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>اطلاعات اشتراک - <%= data.email %></title>
    
    <!-- Google Fonts: Vazirmatn & Roboto -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Roboto:wght@400;500;700&family=Vazirmatn:wght@400;500;700;800&display=swap" rel="stylesheet">
    
    <style>
        :root {
            --bg-color: #0d1117;
            --card-bg: rgba(22, 27, 34, 0.7);
            --card-border: rgba(48, 54, 61, 0.8);
            --text-primary: #e6edf3;
            --text-secondary: #8b949e;
            --accent-blue: #2f81f7;
            --accent-blue-hover: #388bfd;
            --accent-green: #3fb950;
            --accent-red: #f85149;
            --font-fa: 'Vazirmatn', -apple-system, BlinkMacSystemFont, sans-serif;
            --font-en: 'Roboto', -apple-system, BlinkMacSystemFont, sans-serif;
            --radius-xl: 24px;
            --radius-lg: 16px;
            --radius-md: 12px;
            --radius-sm: 8px;
            --shadow-card: 0 12px 32px rgba(0,0,0,0.4);
            --shadow-glow: 0 0 20px rgba(47, 129, 247, 0.15);
            --transition: all 0.3s cubic-bezier(0.25, 0.8, 0.25, 1);
        }

        body {
            margin: 0;
            padding: 0;
            background-color: var(--bg-color);
            color: var(--text-primary);
            font-family: var(--font-fa);
            min-height: 100vh;
            display: flex;
            align-items: center;
            justify-content: center;
            -webkit-font-smoothing: antialiased;
            background-image: 
                radial-gradient(circle at 15% 50%, rgba(47, 129, 247, 0.08), transparent 25%),
                radial-gradient(circle at 85% 30%, rgba(63, 185, 80, 0.05), transparent 25%);
            background-attachment: fixed;
        }

        .container {
            width: 100%;
            max-width: 520px;
            padding: 24px;
            box-sizing: border-box;
            position: relative;
            z-index: 10;
        }

        .glass-card {
            background: var(--card-bg);
            border: 1px solid var(--card-border);
            border-radius: var(--radius-xl);
            padding: 36px 32px;
            box-shadow: var(--shadow-card), var(--shadow-glow);
            backdrop-filter: blur(20px);
            -webkit-backdrop-filter: blur(20px);
            animation: fadeInScale 0.6s cubic-bezier(0.16, 1, 0.3, 1) forwards;
            opacity: 0;
            transform: scale(0.96) translateY(10px);
        }

        @keyframes fadeInScale {
            to {
                opacity: 1;
                transform: scale(1) translateY(0);
            }
        }

        .header {
            text-align: center;
            margin-bottom: 32px;
        }

        .avatar {
            width: 80px;
            height: 80px;
            background: linear-gradient(135deg, #2f81f7 0%, #8957e5 100%);
            border-radius: 50%;
            display: inline-flex;
            align-items: center;
            justify-content: center;
            font-size: 32px;
            font-weight: 800;
            color: white;
            margin-bottom: 16px;
            box-shadow: 0 8px 16px rgba(47, 129, 247, 0.25);
            text-transform: uppercase;
            font-family: var(--font-en);
            border: 2px solid rgba(255,255,255,0.1);
        }

        .title {
            font-size: 26px;
            font-weight: 800;
            margin: 0;
            color: #ffffff;
            letter-spacing: -0.5px;
            font-family: var(--font-en);
        }

        .subtitle {
            font-size: 14px;
            color: var(--text-secondary);
            margin-top: 8px;
            font-weight: 500;
        }

        .status-badge {
            display: inline-flex;
            align-items: center;
            padding: 6px 16px;
            border-radius: 20px;
            font-size: 13px;
            font-weight: 700;
            margin-top: 16px;
            border: 1px solid transparent;
            box-shadow: inset 0 1px 0 rgba(255,255,255,0.05);
        }

        .status-active {
            background-color: rgba(46, 160, 67, 0.15);
            color: var(--accent-green);
            border-color: rgba(46, 160, 67, 0.4);
        }

        .status-inactive {
            background-color: rgba(248, 81, 73, 0.15);
            color: var(--accent-red);
            border-color: rgba(248, 81, 73, 0.4);
        }

        .status-badge::before {
            content: "";
            width: 8px;
            height: 8px;
            border-radius: 50%;
            margin-left: 8px;
        }

        .status-active::before {
            background-color: var(--accent-green);
            box-shadow: 0 0 10px var(--accent-green);
        }

        .status-inactive::before {
            background-color: var(--accent-red);
            box-shadow: 0 0 10px var(--accent-red);
        }

        .copy-section {
            background-color: rgba(1, 4, 9, 0.6);
            border: 1px solid var(--card-border);
            border-radius: var(--radius-md);
            padding: 6px;
            display: flex;
            align-items: center;
            margin-bottom: 32px;
            position: relative;
            transition: var(--transition);
        }

        .copy-section:hover, .copy-section:focus-within {
            border-color: rgba(47, 129, 247, 0.6);
            box-shadow: 0 0 0 2px rgba(47, 129, 247, 0.2);
        }

        .copy-input {
            background: transparent;
            border: none;
            color: var(--text-primary);
            font-family: var(--font-en);
            font-size: 14px;
            padding: 14px 16px;
            flex-grow: 1;
            outline: none;
            direction: ltr;
            text-align: left;
            width: 100%;
        }

        .copy-input::selection {
            background: rgba(47, 129, 247, 0.3);
        }

        .copy-btn {
            background: linear-gradient(180deg, rgba(48, 54, 61, 1), rgba(33, 38, 45, 1));
            color: var(--text-primary);
            border: 1px solid var(--card-border);
            border-radius: var(--radius-sm);
            padding: 12px 24px;
            font-family: var(--font-fa);
            font-size: 14px;
            font-weight: 600;
            cursor: pointer;
            transition: var(--transition);
            white-space: nowrap;
            margin-left: 4px;
            box-shadow: inset 0 1px 0 rgba(255,255,255,0.05);
            display: flex;
            align-items: center;
            gap: 8px;
        }

        .copy-btn svg {
            width: 16px;
            height: 16px;
            fill: currentColor;
        }

        .copy-btn:hover {
            background: var(--text-primary);
            color: var(--bg-color);
            border-color: var(--text-primary);
        }

        .copy-btn:active {
            transform: scale(0.96);
        }

        .grid-stats {
            display: grid;
            grid-template-columns: repeat(2, 1fr);
            gap: 16px;
            margin-bottom: 32px;
        }

        .stat-card {
            background-color: rgba(255, 255, 255, 0.02);
            border: 1px solid var(--card-border);
            border-radius: var(--radius-md);
            padding: 20px;
            text-align: center;
            transition: var(--transition);
            position: relative;
            overflow: hidden;
        }

        .stat-card::after {
            content: '';
            position: absolute;
            top: 0;
            left: 0;
            width: 100%;
            height: 1px;
            background: linear-gradient(90deg, transparent, rgba(255,255,255,0.1), transparent);
        }

        .stat-card:hover {
            background-color: rgba(255, 255, 255, 0.04);
            border-color: rgba(139, 148, 158, 0.4);
            transform: translateY(-4px);
            box-shadow: 0 8px 16px rgba(0,0,0,0.2);
        }

        .stat-icon {
            width: 40px;
            height: 40px;
            margin: 0 auto 12px;
            border-radius: 10px;
            display: flex;
            align-items: center;
            justify-content: center;
        }
        
        .stat-card:nth-child(1) .stat-icon {
            background-color: rgba(137, 87, 229, 0.15);
            color: #d2a8ff;
        }
        
        .stat-card:nth-child(2) .stat-icon {
            background-color: rgba(47, 129, 247, 0.15);
            color: #79c0ff;
        }

        .stat-icon svg {
            width: 20px;
            height: 20px;
            fill: currentColor;
        }

        .stat-label {
            font-size: 13px;
            color: var(--text-secondary);
            margin-bottom: 8px;
            font-weight: 500;
        }

        .stat-value {
            font-size: 24px;
            font-weight: 800;
            color: #ffffff;
            font-family: var(--font-en);
            display: flex;
            align-items: baseline;
            justify-content: center;
            gap: 4px;
        }

        .stat-unit {
            font-size: 13px;
            color: var(--text-secondary);
            font-weight: 600;
            font-family: var(--font-fa);
        }

        .progress-container {
            width: 100%;
            height: 6px;
            background-color: rgba(255,255,255,0.08);
            border-radius: 99px;
            margin-top: 16px;
            overflow: hidden;
            position: relative;
        }

        .progress-bar {
            height: 100%;
            border-radius: 99px;
            background: linear-gradient(90deg, #2f81f7, #79c0ff);
            transition: width 1.2s cubic-bezier(0.25, 0.8, 0.25, 1);
            width: 0%;
            box-shadow: 0 0 10px rgba(47, 129, 247, 0.5);
        }
        
        .progress-bar.danger {
            background: linear-gradient(90deg, #da3633, #ff7b72);
            box-shadow: 0 0 10px rgba(218, 54, 51, 0.5);
        }

        .action-links {
            display: flex;
            gap: 16px;
            justify-content: center;
        }

        .btn-link {
            display: inline-flex;
            align-items: center;
            justify-content: center;
            padding: 14px 24px;
            border-radius: var(--radius-md);
            text-decoration: none;
            font-weight: 600;
            font-size: 14px;
            transition: var(--transition);
            flex: 1;
            gap: 10px;
            box-shadow: inset 0 1px 0 rgba(255,255,255,0.05);
        }

        .btn-link svg {
            width: 20px;
            height: 20px;
            fill: currentColor;
        }

        .btn-telegram {
            background-color: rgba(47, 129, 247, 0.12);
            color: #58a6ff;
            border: 1px solid rgba(47, 129, 247, 0.3);
        }

        .btn-telegram:hover {
            background-color: rgba(47, 129, 247, 0.25);
            border-color: rgba(47, 129, 247, 0.6);
            transform: translateY(-2px);
        }

        .btn-whatsapp {
            background-color: rgba(46, 160, 67, 0.12);
            color: #56d364;
            border: 1px solid rgba(46, 160, 67, 0.3);
        }

        .btn-whatsapp:hover {
            background-color: rgba(46, 160, 67, 0.25);
            border-color: rgba(46, 160, 67, 0.6);
            transform: translateY(-2px);
        }

        .toast {
            position: fixed;
            bottom: 32px;
            left: 50%;
            transform: translateX(-50%) translateY(100px);
            background-color: var(--accent-green);
            color: #000000;
            padding: 14px 28px;
            border-radius: 30px;
            font-weight: 700;
            font-size: 15px;
            box-shadow: 0 8px 24px rgba(63, 185, 80, 0.4);
            opacity: 0;
            transition: all 0.4s cubic-bezier(0.16, 1, 0.3, 1);
            z-index: 1000;
            pointer-events: none;
            display: flex;
            align-items: center;
            gap: 8px;
        }

        .toast svg {
            width: 18px;
            height: 18px;
            fill: currentColor;
        }

        .toast.show {
            transform: translateX(-50%) translateY(0);
            opacity: 1;
        }

        @media (max-width: 480px) {
            .glass-card {
                padding: 28px 20px;
            }
            .grid-stats {
                grid-template-columns: 1fr;
            }
            .action-links {
                flex-direction: column;
            }
        }
    </style>
</head>
<body>

    <div class="container">
        <div class="glass-card">
            <div class="header">
                <div class="avatar"><%= data.email.substring(0, 2) %></div>
                <h1 class="title"><%= data.email %></h1>
                <div class="subtitle">پنل کاربری اشتراک شما</div>
                
                <% if (data.enable) { %>
                    <div class="status-badge status-active">وضعیت: فعال</div>
                <% } else { %>
                    <div class="status-badge status-inactive">وضعیت: غیرفعال</div>
                <% } %>
            </div>

            <div class="copy-section">
                <input type="text" id="subUrl" class="copy-input" value="<%= data.suburl %>" readonly>
                <button class="copy-btn" onclick="copyUrl()">
                    <svg viewBox="0 0 24 24"><path d="M16 1H4c-1.1 0-2 .9-2 2v14h2V3h12V1zm3 4H8c-1.1 0-2 .9-2 2v14c0 1.1.9 2 2 2h11c1.1 0 2-.9 2-2V7c0-1.1-.9-2-2-2zm0 16H8V7h11v14z"/></svg>
                    کپی لینک
                </button>
            </div>

            <%
                const totalGB = (data.total / 1073741824).toFixed(2);
                const usedGB = ((data.up + data.down) / 1073741824).toFixed(2);
                const percentUsed = data.total > 0 ? Math.min(100, Math.round(((data.up + data.down) / data.total) * 100)) : 0;
                const isDanger = percentUsed > 85;
                
                let remainingDays = "نامشخص";
                let remainingDaysVal = -1;
                try {
                    const expiry = parseInt(data.expiryTime, 10);
                    if (expiry === 0) {
                        remainingDays = "بدون انقضا";
                    } else if (expiry > Date.now()) {
                        remainingDaysVal = Math.floor((expiry - Date.now()) / (1000 * 60 * 60 * 24));
                        remainingDays = remainingDaysVal + " روز";
                    } else {
                        remainingDays = "منقضی شده";
                    }
                } catch(e) {}
            %>

            <div class="grid-stats">
                <div class="stat-card">
                    <div class="stat-icon">
                        <svg viewBox="0 0 24 24"><path d="M19 4h-1V2h-2v2H8V2H6v2H5c-1.11 0-1.99.9-1.99 2L3 20a2 2 0 0 0 2 2h14c1.1 0 2-.9 2-2V6c0-1.1-.9-2-2-2zm0 16H5V10h14v10zm0-12H5V6h14v2zm-7 5h5v5h-5z"/></svg>
                    </div>
                    <div class="stat-label">زمان باقیمانده</div>
                    <div class="stat-value">
                        <% if (remainingDaysVal >= 0) { %>
                            <%= remainingDaysVal %> <span class="stat-unit">روز</span>
                        <% } else { %>
                            <span style="font-size: 18px; font-family: var(--font-fa);"><%= remainingDays %></span>
                        <% } %>
                    </div>
                </div>

                <div class="stat-card">
                    <div class="stat-icon">
                        <svg viewBox="0 0 24 24"><path d="M13 2.05v3.03c3.39.49 6 3.39 6 6.92 0 .9-.22 1.76-.61 2.53l2.5 2.5c1.33-1.42 2.11-3.32 2.11-5.03 0-4.97-4.03-9-9-9zM12 19c-3.87 0-7-3.13-7-7 0-3.53 2.61-6.43 6-6.92V2.05c-5.06.5-9 4.76-9 9.95 0 5.52 4.47 10 9.99 10 3.31 0 6.24-1.61 8.06-4.09l-2.6-2.6C16.17 17.17 14.22 19 12 19z"/></svg>
                    </div>
                    <div class="stat-label">ترافیک مصرف شده</div>
                    <div class="stat-value">
                        <%= usedGB %> <span class="stat-unit">/ <%= data.total === 0 ? '∞' : totalGB %> GB</span>
                    </div>
                    <% if (data.total > 0) { %>
                        <div class="progress-container">
                            <div class="progress-bar <%= isDanger ? 'danger' : '' %>" style="width: 0%" data-target="<%= percentUsed %>%"></div>
                        </div>
                    <% } %>
                </div>
            </div>

            <div class="action-links">
                <% if (data.TELEGRAM_URL) { %>
                <a href="<%= data.TELEGRAM_URL %>?text=سلام من شناسه <%= data.email %> هستم" target="_blank" class="btn-link btn-telegram">
                    <svg viewBox="0 0 24 24"><path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm4.64 6.8c-.15 1.58-.8 5.42-1.13 7.19-.14.75-.42 1-.68 1.03-.58.05-1.02-.38-1.58-.75-.88-.58-1.38-.94-2.23-1.5-.99-.65-.35-1.01.22-1.59.15-.15 2.71-2.48 2.76-2.69.01-.03.01-.14-.07-.19-.08-.05-.19-.02-.27 0-.11.03-1.84 1.18-5.18 3.44-.49.33-.93.5-1.33.49-.44-.01-1.28-.25-1.9-.45-.77-.25-1.38-.38-1.33-.8.03-.22.35-.45.98-.69 3.85-1.68 6.41-2.78 7.69-3.32 3.65-1.53 4.41-1.8 4.9-1.81.11 0 .35.03.5.15.13.1.17.24.18.35-.01.07-.01.21-.02.3z"/></svg>
                    پشتیبانی تلگرام
                </a>
                <% } %>
                
                <% if (data.WHATSAPP_URL) { %>
                <a href="<%= data.WHATSAPP_URL %>?text=سلام من شناسه <%= data.email %> هستم" target="_blank" class="btn-link btn-whatsapp">
                    <svg viewBox="0 0 24 24"><path d="M19.05 4.91A9.816 9.816 0 0 0 12.04 2c-5.46 0-9.91 4.45-9.91 9.91 0 1.75.46 3.45 1.32 4.95L2 22l5.25-1.38c1.45.8 3.08 1.22 4.79 1.22 5.46 0 9.91-4.45 9.91-9.91 0-2.65-1.03-5.14-2.9-7.02zm-7.01 15.24c-1.48 0-2.93-.4-4.2-1.15l-.3-.18-3.12.82.83-3.04-.2-.31a8.264 8.264 0 0 1-1.26-4.38c0-4.54 3.7-8.24 8.24-8.24 2.2 0 4.27.86 5.82 2.42a8.183 8.183 0 0 1 2.41 5.83c.02 4.54-3.68 8.23-8.22 8.23zm4.52-6.16c-.25-.12-1.47-.72-1.69-.81-.23-.08-.39-.12-.56.12-.17.25-.64.81-.79.98-.15.17-.3.19-.55.07-.25-.12-1.05-.39-2-1.24-.74-.66-1.23-1.47-1.38-1.72-.15-.25-.02-.38.11-.51.11-.11.25-.29.37-.43s.17-.25.25-.41c.08-.17.04-.31-.02-.43s-.56-1.34-.76-1.84c-.2-.48-.41-.42-.56-.43h-.48c-.17 0-.45.06-.69.32-.25.25-.94.92-.94 2.24s.96 2.6 1.1 2.78c.14.19 1.9 2.9 4.58 4.06.64.28 1.14.45 1.53.58.64.2 1.22.17 1.68.1.51-.08 1.47-.6 1.68-1.18.21-.58.21-1.08.15-1.18-.05-.1-.22-.16-.47-.28z"/></svg>
                    پشتیبانی واتساپ
                </a>
                <% } %>
            </div>
        </div>
    </div>

    <div id="toast" class="toast">
        <svg viewBox="0 0 24 24"><path d="M9 16.17L4.83 12l-1.42 1.41L9 19 21 7l-1.41-1.41z"/></svg>
        لینک با موفقیت کپی شد!
    </div>

    <script>
        function copyUrl() {
            const input = document.getElementById('subUrl');
            input.select();
            input.setSelectionRange(0, 99999);
            
            try {
                navigator.clipboard.writeText(input.value).then(() => {
                    showToast();
                }).catch(() => {
                    document.execCommand('copy');
                    showToast();
                });
            } catch (err) {
                document.execCommand('copy');
                showToast();
            }
        }

        function showToast() {
            const toast = document.getElementById('toast');
            toast.classList.add('show');
            setTimeout(() => {
                toast.classList.remove('show');
            }, 3000);
        }

        // Animate progress bars on load
        document.addEventListener("DOMContentLoaded", () => {
            setTimeout(() => {
                const bars = document.querySelectorAll('.progress-bar');
                bars.forEach(bar => {
                    bar.style.width = bar.getAttribute('data-target');
                });
            }, 300);
        });
    </script>
</body>
</html>
