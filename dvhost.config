# ==========================================
# Configuration File for 3x-ui Subscription Panel
# ==========================================

# Protocol used to connect to your 3x-ui panel (http or https)
PROTOCOL=http

# Your 3x-ui Panel Domain or IP Address (e.g., panel.domain.com or 1.2.3.4)
HOST=

# Your 3x-ui Panel Port
PORT=2020

# Your 3x-ui Panel Base Path (Leave empty if none)
PATH=

# ==========================================
# Authentication (API_TOKEN is highly recommended)
# ==========================================
# Generate an API Token in your 3x-ui panel: Settings -> Security -> API Token
API_TOKEN=

# Fallback Legacy Authentication (Ignored if API_TOKEN is provided)
USERNAME=admin
PASSWORD=admin

# Legacy 2FA AUTH (Only used if falling back to Username/Password)
TWO_FACTOR=false
TOTP_SECRET=

# ==========================================
# Subscription Server Settings
# ==========================================
# The public link where clients will access their subscriptions.
# Example: http://sub.domain.com:2082/sub/
SUBSCRIPTION=http://ip_or_domain:2096/sub/

# HTTP and HTTPS ports for this subscription Node.js app
SUB_HTTP_PORT=2082
SUB_HTTPS_PORT=2083

# (Optional) SSL Certificates for HTTPS Subscription Links
#PUBLIC_KEY_PATH=/root/cert/test.domain.top/fullchain.pem
#PRIVATE_KEY_PATH=/root/cert/test.domain.top/privkey.pem

# ==========================================
# Template & UI Settings
# ==========================================
# Directory name of the template inside views/templates/
TEMPLATE_NAME=default

# Default language for the template UI (e.g., fa, en)
DEFAULT_LANG=fa

# Telegram/WhatsApp Support Links for the UI
TELEGRAM_URL=https://t.me/dvhost_cloud
WHATSAPP_URL=https://w.me/dvhost_cloud

# Fallback Backup Link
Backup_link=

# ==========================================
# Advanced Features (Warnings & Announcements)
# ==========================================
# Trigger a warning dummy config when traffic is below this MB (0 to disable)
LOW_DATA_WARNING_MB=100

# Trigger a warning dummy config when days remaining are below this (0 to disable)
LOW_TIME_WARNING_DAYS=3

# Global Announcements in format: color:message|color:message
# Colors: info, warning, danger, success
# Example: ANNOUNCEMENTS="danger:Maintenance tonight|info:Welcome!"
ANNOUNCEMENTS=